# --- AirTwin India ---
# Copy this file to .env and fill in what you have.
# Everything is optional — the system falls back to synthetic data
# and a no-Ion Cesium globe if these are missing.

# Cesium Ion token (free tier): https://ion.cesium.com/tokens
# With a token → terrain + OSM buildings over Delhi.
# Without    → plain blue globe; station markers still render.
CESIUM_ION_TOKEN=

# OpenWeatherMap API key (free tier): https://openweathermap.org/api
# Used for the optional live air-pollution + weather overlay.
OPENWEATHER_API_KEY=

# data.gov.in API key (optional): https://data.gov.in
# Used by the CPCB slow-path resource fetcher.
DATA_GOV_IN_API_KEY=

# Backend tick cadence for the WebSocket broadcast (seconds).
TICK_SECONDS=7

# Frontend → Backend base URLs (vite env)
VITE_API_BASE=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
VITE_CESIUM_ION_TOKEN=
